{
  "name": "sherlockbones",
  "version": "0.1.0",
  "description": "Run only the tests that cover the code you just changed — instantly.",
  "type": "module",
  "license": "MIT",
  "author": "Jeremy D. Fabian",
  "keywords": [
    "test",
    "tests",
    "vitest",
    "coverage",
    "test-impact-analysis",
    "test-selection",
    "claude-code",
    "codex",
    "ai-agents"
  ],
  "homepage": "https://github.com/JeremyDFabian/sherlockbones#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeremyDFabian/sherlockbones.git"
  },
  "bugs": {
    "url": "https://github.com/JeremyDFabian/sherlockbones/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "bones": "dist/cli/index.js",
    "sherlockbones": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/sample-app.ts",
    "bench:daemon": "npm run build && tsx bench/daemon-latency.ts",
    "bench:coverage": "npm run build && tsx bench/coverage-overhead.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "@vitest/coverage-istanbul": ">=3.0.0",
    "vitest": ">=3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-istanbul": "^3.2.6",
    "eslint": "^9.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
